# Create a project at https://dashboard.reown.com and keep the ID scoped to
# the deployed Setwise origin.
VITE_REOWN_PROJECT_ID=

# Leave blank in local/forwarded development to derive window.location.origin.
# Set the exact public HTTPS origin in deployed environments.
VITE_APP_URL=

# Optional fallback used when AppKit is intentionally not configured.
VITE_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
VITE_BSC_TESTNET_EXPLORER_URL=https://testnet.bscscan.com

VITE_RFQ_API_URL=https://setwise-rfq-api.datadex.workers.dev
# Presentation metadata only. RFQ discovery still controls tradable assets.
VITE_TOKEN_LIST_URL=https://raw.githubusercontent.com/cenodev/setwise-token-list/main/data/token-list.json
# Legacy redirect/default only. All Sets are discovered from GET /v1/pools.
VITE_POOL_ID=bstock-ai-no-bnb-bsc-testnet

# Amount retained by native-input Max calculations for transaction gas.
VITE_NATIVE_GAS_RESERVE_BNB=0.001
