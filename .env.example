# Create a project at https://dashboard.reown.com and keep the ID scoped to
# the deployed Setwise origin.
VITE_REOWN_PROJECT_ID=

# Leave blank in local/forwarded development to derive window.location.origin.
# Set the exact public HTTPS origin in deployed environments.
VITE_APP_URL=

# Optional fallback used when AppKit is intentionally not configured.
VITE_BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Added in the RFQ integration task.
VITE_RFQ_API_URL=http://localhost:8787
